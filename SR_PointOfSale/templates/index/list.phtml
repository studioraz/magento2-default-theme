declare(strict_types=1);

use SR\PointOfSale\Block\Index\PointOfSales;
use SR\PointOfSale\ViewModel\PointOfSaleViewModel;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\LucideIcons;
use Magento\Framework\Escaper;

/** @var PointOfSales $block */
/** @var PointOfSaleViewModel $pointOfSaleViewModel */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var LucideIcons $lucideIcons */

$lucideIcons = $viewModels->require(LucideIcons::class);
$pointOfSaleViewModel = $block->getData('pointofsale_view_model');
$collection = $block->getPointOfSaleCollection();

function wrapTextLinesInSpans(string $text): string
{
    $lines = explode("\n", trim($text));
    return implode('', array_map(fn($line) => '<span class="bg-gray-100 py-[4px] px-[6px] mb-[2px] rounded-[8px] text-sm font-normal leading-5 inline-block whitespace-nowrap me-[4px]">' . $line . '</span>', $lines));
}
?>

<?php if ($collection->getTotalCount() > 0): ?>
    <div class="pointofsale-wrapper mb-5">
        <?php foreach ($collection->getItems() as $pointOfSale): ?>
            <?php $pointOfSaleViewModel->setPointOfSale($pointOfSale); ?>
