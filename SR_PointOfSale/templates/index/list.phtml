                    <ul class="store-info flex text-base md:text-lg mt-[10px] [&>li]:flex-grow max-md:[&>li]:basis-0 [&>li]:mt-0 md:[&>li]:mb-[10px] px-[16px] lg:px-[24px]">
                        <li class="address lg:basis-[15%]">
