<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="page.main.title">
            <arguments>
                <argument name="text_css" xsi:type="string">page-title text-center text-xl md:text-3xl font-medium mb-[8px] lg:mb-0</argument>
            </arguments>
        </referenceBlock>

        <referenceBlock name="pointofsale_index_description" remove="true"/>
    </body>
</page>
