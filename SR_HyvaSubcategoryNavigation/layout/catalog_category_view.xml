<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="page.main.title">
            <block class="SR\HyvaSubcategoryNavigation\Block\Category\SubcategoryNavigation"
                   name="subcategory.navigation"
                   as="subcategory_navigation"
                   template="SR_HyvaSubcategoryNavigation::category/subcategory-navigation.phtml"
                   after="-"/>
        </referenceBlock>

        <move element="category.description" destination="page.main.title" after="subcategory.navigation"/>
    </body>
</page>
