<?php
/**
 * @var $block  \Mirasvit\LayeredNavigation\Block\Renderer\SwatchRenderer
 * @var $escaper \Magento\Framework\Escaper
 */

use Magento\Swatches\Model\Swatch;

$swatchData    = $block->getSwatchData();
$attributeCode = $swatchData['attribute_code'];
$attributeId   = $swatchData['attribute_id'];
$filter        = $block->getSwatchFilter();

$isMultiselect = (int)$block->isMultiselectEnabled();

$useAlphabeticalIndex = strpos(get_class($filter), 'AttributeFilter') !== false
    && $filter->isUseAlphabeticalIndex();

$checkedItemsCount = 0;
$letter            = '';
?>

<div class="swatch-attribute swatch-layered <?= $escaper->escapeHtmlAttr($attributeCode) ?> mst-nav__swatch"
     data-attribute-code="<?= $escaper->escapeHtmlAttr($attributeCode) ?>"
     data-is-multiselect="<?= $escaper->escapeHtmlAttr($isMultiselect) ?>"
     attribute-id="<?= $escaper->escapeHtmlAttr($attributeId) ?>"
     x-data="{...initLabelRenderer(), ...initSwatchRenderer()}"
>
    <div class="swatch-attribute-options clearfix flex flex-row flex-wrap" data-mst-nav-filter="<?= $escaper->escapeHtmlAttr($attributeCode) ?>">
        <?= $block->getSearchBoxElement($attributeCode) ?>
        <div data-holder="alphabetical"
             x-data="initAlphabeticalIndex(<?= (int)($useAlphabeticalIndex && $filter->isAlphabeticalIndexAllowedByLimit()) ?>, <?= $filter->getAlphabeticalLimit() ?>)"
             x-init="init()"
             class="block w-full"
        ></div>

        <?php foreach ($swatchData['options'] as $option => $label): ?>
            <?php
            if (!$option || empty(trim($label['label']))) {
                continue;
            }

            if (!isset($swatchData['swatches'][$option])) {
                $swatchData['swatches'][$option] = [
                    'type'  => 0,
                    'label' => $label['label'],
                    'value' => $label['label'],
                ];
            }

            $swatchType  = (string)$swatchData['swatches'][$option]['type'];
            $swatchValue = (string)($swatchData['swatches'][$option]['value'] ?? '');
            $isGroupedOption = isset($swatchData['swatches'][$option]['grouped']);

            // Build PHP-side inline style so the swatch is always visible,
            // even before / without Alpine.js initialisation.
            $inlineStyle = '';
            if ($swatchType === (string)Swatch::SWATCH_TYPE_VISUAL_COLOR) {
                // type 1 – colour swatch
                $inlineStyle = 'background-color:' . $escaper->escapeHtmlAttr($swatchValue) . ';';
            } elseif ($swatchType === (string)Swatch::SWATCH_TYPE_VISUAL_IMAGE) {
                // type 2 – image swatch
                $imagePath = $block->getSwatchFilePath('swatch_image', $swatchValue, $isGroupedOption);
                if ($imagePath) {
                    $style = 'background:#fff url(' . $escaper->escapeUrl($imagePath) . ') no-repeat center;';
                    $style .= strpos($imagePath, 'mst_nav_group') !== false
                        ? 'background-size:contain;'
                        : 'background-size:cover;';
                    $inlineStyle = $style;
                }
            }

            // Visual swatches get fixed square dimensions (equivalent to w-6 h-6 = 1.5rem)
            $isVisualSwatch = in_array($swatchType, [
                (string)Swatch::SWATCH_TYPE_VISUAL_COLOR,
                (string)Swatch::SWATCH_TYPE_VISUAL_IMAGE,
            ], true);
            if ($isVisualSwatch) {
                $inlineStyle .= 'width:1.5rem;height:1.5rem;';
            }

            $isItemChecked = $block->isItemChecked($option);
            $url           = $isItemChecked
                ? $block->getRemoveUrl($attributeCode, $option)
                : $block->getSwatchOptionLink($attributeCode, $option);

            if ($isItemChecked) {
                $checkedItemsCount++;
            }

            $customStyle = isset($label['custom_style']) ? $escaper->escapeHtmlAttr($label['custom_style']) : '';
            ?>

            <?php if ($useAlphabeticalIndex && $filter->isSortByLabel() && $letter !== $block->getFirstLetter($label['label'])):
                $letter = $block->getFirstLetter($label['label']); ?>
                <div class="mst-nav__letter mst-nav__label-item"
                     data-letter="<?= $escaper->escapeHtmlAttr($letter) ?>"
                     data-element="filter"
                     role="separator"
                     aria-label="<?= $escaper->escapeHtmlAttr(__('Letter %1', $letter)) ?>"
                     tabindex="0"
                >
                    <b><?= $escaper->escapeHtml($letter) ?></b>
                </div>
            <?php endif; ?>

            <a href="<?= $escaper->escapeUrl($url) ?>"
               data-element="filter"
               data-hidden="false"
               data-search-hidden="false"
               data-letter-hidden="false"
               data-value="<?= $escaper->escapeHtmlAttr($option) ?>"
               aria-label="<?= $escaper->escapeHtmlAttr($isItemChecked ? __('Remove filter: %1', $label['label']) : __('Filter by %1', $label['label'])) ?>"
                <?= $useAlphabeticalIndex ? 'data-letter="' . $escaper->escapeHtmlAttr($block->getFirstLetter($label['label'])) . '"' : '' ?>
               @click="handleClick"
               class="<?= $isItemChecked ? '_checked ring ring-primary' : '' ?> swatch-option relative shadow-sm cursor-pointer select-none<?= $isVisualSwatch ? '' : ' px-2' ?> product-option-value-label <?= $isVisualSwatch ? 'border border-container-darker' : 'bg-container-lighter border-container-darker' ?>"
               style="<?= /* @noEscape */ $inlineStyle ?>"
               rel="<?= $escaper->escapeHtmlAttr($block->getRelAttributeValue()) ?>"
               role="checkbox"
               aria-checked="<?= $isItemChecked ? 'true' : 'false' ?>"
               tabindex="0"
                <?php
                $swatchThumbPath = '';
                if ($swatchType === (string)Swatch::SWATCH_TYPE_VISUAL_IMAGE) {
                    $swatchThumbPath = $block->getSwatchFilePath('swatch_thumb', $swatchValue, $isGroupedOption);
                }
                ?>
               @mouseenter.self="activeTooltipItem = {
                       attribute: '<?= $escaper->escapeHtmlAttr($swatchValue) ?>',
                       type: '<?= $escaper->escapeHtmlAttr($swatchType) ?>',
                       id: '<?= $escaper->escapeHtmlAttr($option) ?>',
                       label: '<?= $escaper->escapeHtmlAttr($label['label']) ?>',
                       thumb: '<?= $escaper->escapeUrl($swatchThumbPath) ?>',
                       value: '<?= $escaper->escapeHtmlAttr($swatchValue) ?>'
                   }; tooltipPositionElement = $event.target;"
               @mouseleave.self="activeTooltipItem = false"
            >
                <?php if (!$isVisualSwatch): ?>
                    <?= $escaper->escapeHtml($swatchValue ?: $label['label']) ?>
                <?php endif; ?>
            </a>
        <?php endforeach; ?>
    </div>

    <?= /* @noEscape */ $block->getBlockHtml('product.swatch.tooltip') ?>

    <div class="hidden mst-clear-options-link" data-checked-count="<?= $checkedItemsCount ?>">
        <div class="mst-nav__checked-counter__wrapper font-normal flex items-center mx-2">
            <div class="mst-nav__checked-counter rounded px-2 bg-gray-200 mr-1"><?= $checkedItemsCount ?></div>
            <a class="hover:underline text-2xl opacity-50"
               href="<?= $escaper->escapeUrl($block->getAttributeClearUrl($attributeCode)) ?>"
               rel="<?= $escaper->escapeHtmlAttr($block->getRelAttributeValue()) ?>"
               data-element="filter"
               aria-label="Clear filter">&#10005;</a>
        </div>
    </div>
</div>

