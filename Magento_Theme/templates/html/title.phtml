declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Theme\Block\Html\Title;
use SR\HyvaBaseModule\ViewModel\Html\PageTitle;

/**
 * @var Escaper $escaper
 * @var Title $block
 * @var ViewModelRegistry $viewModels
 * @var PageTitle $viewModel
 */

$viewModel = $viewModels->require(PageTitle::class);
$viewModel->setBlock($block);

$wrapperCss = $viewModel->getCssClass('wrapper_css');
$wrapperContainerCss = $viewModel->getCssClass('wrapper_container_css');
$wrapperBlockCss = $viewModel->getCssClass('wrapper_block_css');
$wrapperSpacingCss = $viewModel->getCssClass('wrapper_spacing_css');
$wrapperAdditionalCss = $viewModel->getCssClass('wrapper_additional_css');
$textCss = $viewModel->getCssClass('text_css');
$textAdditionalCss = $viewModel->getCssClass('text_additional_css');

$legacyCss = $block->getCssClass();

$titleHtml = '';
if (trim((string)$block->getPageHeading())) {
    $titleHtml = '<span class="base" data-ui-id="page-title-wrapper" '
        . $block->getAddBaseAttribute()
        . '>'
        . $escaper->escapeHtml($block->getPageHeading(), ['strong', 'br'])
        . '</span>';
}
?>
<?php if ($titleHtml): ?>
<div class="<?= $wrapperCss ?> <?= $wrapperContainerCss ?> <?= $wrapperBlockCss ?> <?= $wrapperSpacingCss ?> <?= $wrapperAdditionalCss ?> <?= $legacyCss ?>">
    <h1 class="page-title title-font <?= $textCss ?> <?= $textAdditionalCss ?>"
        <?php if ($block->getId()): ?> id="<?= $escaper->escapeHtmlAttr($block->getId()) ?>" <?php endif; ?>>
        <?= /* @noEscape */ $titleHtml ?>
    </h1>
    <?= $block->getChildHtml() ?>
</div>
<?php endif; ?>
