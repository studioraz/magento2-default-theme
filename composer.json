{
    "name": "studioraz/magento2-default-theme",
    "description": "Default Hyvä Theme",
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "require": {
        "php": ">=7.3.0",
        "magento/framework": ">=102.0.0",
        "hyva-themes/magento2-base-layout-reset": "^2.0.1",
        "hyva-themes/magento2-theme-module": ">=1.4.5",
        "hyva-themes/magento2-email-module": "*",
        "hyva-themes/magento2-graphql-tokens": "*",
        "hyva-themes/magento2-graphql-view-model": ">=1.0.1",
        "hyva-themes/magento2-order-cancellation-webapi": "^1.0.0",
        "magento/module-catalog-rule-graph-ql": "*",
        "magento/module-customer-graph-ql": "*",
        "magento/module-directory-graph-ql": "*",
        "magento/module-graph-ql": "*",
        "magento/module-quote-graph-ql": "*",
        "hyva-themes/magento2-payment-icons": "^1.0",
        "hyva-themes/magento2-cms-tailwind-jit" : "^1.0",
        "studioraz/magento2-hyva-base-module": "^2.7",
        "studioraz/magento2-hyva-checkout-fallback-theme": "^2.1.1|dev-master",
        "studioraz/magento2-hyva-snowdog-menu": "^1.1.1|dev-master",
        "studioraz/magento2-hyva-product-qty-spinner" : "^2.0|dev-master"
    },
    "replace": {
        "hyva-themes/magento2-default-theme": "*"
    },
    "type": "magento2-theme",
    "authors": [
        {
            "name": "Hyvä Themes B.V.",
            "email": "info@hyva.io"
        }
    ],
    "license": [
        "OSL-3.0",
        "AFL-3.0"
    ],
    "autoload": {
        "files": [
            "registration.php"
        ]
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "dev-master",
        "magento/magento-coding-standard": "dev-master",
        "phpro/grumphp": "dev-master"
    },
    "archive": {
        "exclude": [
            ".gitlab"
        ]
    }
}
