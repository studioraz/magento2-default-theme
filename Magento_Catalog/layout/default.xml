<page
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <referenceContainer name="head.additional">
            <block
                name="view-transition.gallery"
                template="Magento_Catalog::page/js/view-transition-between-gallery.phtml"
                ifconfig="hyva_theme_general/animations/enable_view_transition_gallery"
            />
        </referenceContainer>

        <referenceContainer name="sidebar.additional">
            <block
                name="catalog.compare.sidebar"
                template="Magento_Catalog::product/compare/sidebar.phtml"
                ifconfig="catalog/frontend/show_sidebar_in_list"
            />
        </referenceContainer>

        <referenceBlock name="catalog.compare.link.logged.in" display="false"/>

        <referenceBlock name="header.customer.logged.out.links">
            <block name="catalog.compare.link.logged.out" template="Magento_Catalog::product/compare/link.phtml">
                <arguments>
                    <argument name="sort_order" xsi:type="number">0</argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceContainer name="before.body.end">
            <block name="product.addtocart.init" template="Magento_Catalog::product/js/add-to-cart.phtml"/>
            <block name="pagebuilder.image.carousel" template="Magento_PageBuilder::widgets/image-carousel.phtml"/>
        </referenceContainer>
    </body>
</page>
