use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SwatchRenderer;
use Magento\Framework\Escaper;
use Magento\Swatches\Block\Product\Renderer\Configurable;
use Magento\Swatches\ViewModel\Product\Renderer\Configurable as ConfigurableViewModel;

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Configurable $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var ConfigurableViewModel $configurableViewModel */
$configurableViewModel = $viewModels->require(ConfigurableViewModel::class);

/** @var SwatchRenderer $swatchRendererViewModel */
$swatchRendererViewModel = $viewModels->require(SwatchRenderer::class);

$product = $block->getProduct();
$productId = $product->getId();

$attributes = $block->decorateArray($block->getAllowAttributes());

$layout = $block->getLayout();
$swatchItemBlock = $layout->getBlock('product.swatch.item');
$swatchItemBlock->setData('product_id', $productId);

$swatchValidationMessages = [];
foreach ($attributes as $attribute) {
    $productAttribute = $attribute->getProductAttribute();
    if ($swatchRendererViewModel->isSwatchAttribute($productAttribute)) {
        $swatchValidationMessages[(int) $attribute->getAttributeId()] = (string) __(
            'Please select %1.',
            $productAttribute->getStoreLabel()
        );
    }
}
$swatchAttributeIds = array_keys($swatchValidationMessages);

$tooltipBlockHtml = $block->getBlockHtml('product.swatch.tooltip');
?>
<?php if ($product->isSaleable() && count($attributes)): ?>
    <script>
        function initConfigurableSwatchOptions_<?= (int) $productId ?>() {
            const configurableOptionsComponent = initConfigurableOptions(
                '<?= (int) $productId ?>',
                <?= /* @noEscape */ $block->getJsonConfig() ?>
            );
            const swatchOptionsComponent = initSwatchOptions(
                <?= /* @noEscape */ $block->getJsonSwatchConfig() ?>
            );

            return Object.assign(
                configurableOptionsComponent,
                swatchOptionsComponent,
                {
                    swatchValidationErrors: {},
                    swatchAttributeIds: <?= /* @noEscape */ json_encode($swatchAttributeIds) ?>,
                    swatchValidationMessages: <?= /* @noEscape */ json_encode(
                        $swatchValidationMessages,
                        JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP
                    ) ?>,
                    initSwatchValidation() {
                        const form = this.$root.closest('form') || document.getElementById('product_addtocart_form');

                        if (!form) {
                            return;
                        }

                        const showMissingSwatches = () => this.validateSwatchesForAddToCart(form);
                        const submitButtons = new Set([
                            ...form.querySelectorAll('button[type="submit"], input[type="submit"], button:not([type])'),
                            ...document.querySelectorAll(`[form="${form.id}"][type="submit"], button[form="${form.id}"]:not([type])`),
                            ...document.querySelectorAll('#product-addtocart-button')
                        ]);

                        submitButtons.forEach(button => {
                            button.addEventListener('click', showMissingSwatches, true);
                        });
                        form.addEventListener('submit', showMissingSwatches, true);
                    },
                    validateSwatchesForAddToCart(form) {
                        const validationErrors = {};

                        this.swatchAttributeIds.forEach(attributeId => {
                            const hasAvailableOptions = this.getAllowedAttributeOptions(attributeId).length > 0
                                || (this.optionConfig.attributes[attributeId]?.options || []).length > 0;
                            const hasSelection = !!this.selectedValues[attributeId];
                            const hasError = hasAvailableOptions && !hasSelection;
                            const radios = form.querySelectorAll(
                                `input.product-option-value-input[name="super_attribute[${attributeId}]"]`
                            );

                            radios.forEach(radio => {
                                radio.setCustomValidity(hasError ? this.swatchValidationMessages[attributeId] : '');
                            });

                            validationErrors[attributeId] = hasError;
                        });

                        this.swatchValidationErrors = Object.assign({}, this.swatchValidationErrors, validationErrors);
                    },
                    showSwatchValidation(attributeId, event) {
                        const input = event && event.target;

                        if (input && input.validity && input.validity.valueMissing) {
                            input.setCustomValidity(this.swatchValidationMessages[attributeId] || input.validationMessage);
                        }

                        this.swatchValidationErrors = Object.assign({}, this.swatchValidationErrors, {
                            [attributeId]: true
                        });
                    },
                    clearSwatchValidation(attributeId, event) {
                        const input = event && event.target;

                        if (input) {
                            const form = input.form || input.closest('form');
                            const radios = form
                                ? form.querySelectorAll(`[name="${input.name}"]`)
                                : [input];

                            radios.forEach(radio => radio.setCustomValidity(''));
                        }

                        this.swatchValidationErrors = Object.assign({}, this.swatchValidationErrors, {
                            [attributeId]: false
                        });
                    }
                }
            );
        }
    </script>

    <div x-data="initConfigurableSwatchOptions_<?= (int) $productId ?>()"
         x-init="initSwatchValidation()"
         @private-content-loaded.window="onGetCartData($event.detail.data)"
         class="relative mb-6"
         x-defer="intersect"
    >
        <div>
            <?php foreach ($attributes as $attribute): ?>
                <?php $attributeId = $attribute->getAttributeId(); ?>
                <?php $productAttribute = $attribute->getProductAttribute();  ?>
                <?php if ($swatchRendererViewModel->isSwatchAttribute($productAttribute)): ?>
                    <div class="swatch-attribute border-t last:border-b border-gray-300 min-h-14
                            <?= $escaper->escapeHtmlAttr($productAttribute->getAttributeCode()) ?>">
                        <div class="flex flex-col items-center sm:items-start py-2 w-full border-gray-300">
                            <label
                                    class="w-full text-start text-gray-700 label product-option-label"
                                    id="attribute-label-<?= $escaper->escapeHtmlAttr($productId . '-' . $attributeId) ?>"
                                    aria-hidden="true"
                            >
                                <span><?= $escaper->escapeHtml($productAttribute->getStoreLabel()) ?></span>
                                <span
                                        class="text-gray-900 ml-2 font-bold"
                                        x-text="getSwatchText(<?= (int) $attributeId ?>, selectedValues[<?= (int) $attributeId ?>])"
                                ></span>
                            </label>
                            <div class="w-full text-left text-gray-900 product-option-values relative">
                                <div
                                     class="flex items-center -mx-1 space-x-1.5 swatch-attribute-options"
                                     role="radiogroup"
                                     aria-label="<?= $escaper->escapeHtmlAttr($productAttribute->getStoreLabel()) ?>"
                                     aria-describedby="attribute-validation-<?= $escaper->escapeHtmlAttr($productId . '-' . $attributeId) ?>"
                                >
                                    <template
                                        x-for="(item, index) in optionConfig.attributes[<?= (int) $attributeId ?>].options"
                                        :key="item.id"
                                    >
                                        <?= /* @noEscape */ $swatchItemBlock->setData('attribute_id', $attributeId)->toHtml(); ?>
                                    </template>
                                </div>
                                <p
                                    id="attribute-validation-<?= $escaper->escapeHtmlAttr($productId . '-' . $attributeId) ?>"
                                    class="swatch-validation-note"
                                    role="alert"
                                    x-cloak
                                    x-show="swatchValidationErrors[<?= (int) $attributeId ?>]"
                                >
                                    <?= $escaper->escapeHtml($swatchValidationMessages[(int) $attributeId]) ?>
                                </p>
                            </div>
                        </div>
                    </div>
                <?php else: ?>
                    <div class="flex flex-col items-center sm:items-start py-2 w-full border-t border-gray-300 last:border-b">
                        <label class="w-full sm:w-1/2 text-start text-gray-700 label"
                               for="attribute<?= $escaper->escapeHtmlAttr($attributeId) ?>"
                        >
                            <span>
                                <?= $escaper->escapeHtml($attribute->getProductAttribute()->getStoreLabel()) ?>
                            </span>
                        </label>
                        <div class="w-full sm:ml-2 sm:w-1/2 text-start text-gray-900">
                            <select name="super_attribute[<?= $escaper->escapeHtmlAttr($attribute->getAttributeId()) ?>]"
                                    id="attribute<?= $escaper->escapeHtmlAttr($attributeId) ?>"
                                    class="form-select super-attribute-select max-w-full w-full"
                                    x-on:change="changeOption(<?= (int) $attributeId ?>, event.target.value)"
                                    required>
                                <option value="">
                                    <?= $escaper->escapeHtml(__('Choose an Option...')) ?>
                                </option>
                                <template
                                    x-for="(item, index) in getAllAttributeOptions(<?= (int) $attributeId ?>)"
                                    :key="item.id"
                                >
                                    <template x-if="optionIsEnabled(<?= (int) $attributeId ?>, item.id)">
                                        <option
                                            :value="item.id"
                                            x-html="item.label"
                                            :disabled="!optionIsActive(<?= (int) $attributeId ?>, item.id)"
                                            :selected="selectedValues[<?= $escaper->escapeHtmlAttr($attributeId) ?>] === item.id">
                                        </option>
                                    </template>
                                </template>
                            </select>
                        </div>
                    </div>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
        <?= /* @noEscape */ $tooltipBlockHtml ?>
    </div>

<?php endif;?>
